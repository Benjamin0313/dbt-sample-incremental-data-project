# Snowflake 接続 (datum 標準のキーペア認証)。dbt(profiles.yml) と generator(generate.py) が共用。
# このファイルを .env にコピーして値を埋め、`set -a; source .env; set +a` で読み込む。
#   cp .env.sample .env
# ※ .env は .gitignore 済み(コミットされない)。.env.sample のみコミットする。
export SF_ACCOUNT=xxxxxxx.ap-northeast-1.aws
export SF_USER=you@datumstudio.jp
export SF_PRIVATE_KEY_PATH=/path/to/your_snowflake_key.p8
export SF_ROLE=accountadmin
export SF_WAREHOUSE=your_wh
export SF_DATABASE=your_db
export SF_SCHEMA=jaffle_shop          # dbt のモデルスキーマ。源泉は <SF_SCHEMA>_raw に入る
